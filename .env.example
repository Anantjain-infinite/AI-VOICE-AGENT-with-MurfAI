# ---- Required for core voice pipeline ----
MURF_API_KEY=your-murf-api-key
ASSEMBLY_AI_API_KEY=your-assemblyai-api-key
GEMINI_API_KEY=your-gemini-api-key

# ---- Required for finance/weather skills ----
FINNHUB_API_KEY=your-finnhub-api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key
OPENWEATHER_API_KEY=your-openweather-api-key

# ---- Optional (extra finance skill fallbacks) ----
POLYGON_API_KEY=
COINMARKETCAP_API_KEY=

# ---- Persistence paths (defaults are usually fine) ----
DB_PATH=app_data.db
CHROMA_PATH=./chroma_db
UPLOAD_DIR=uploads/pdfs

# ---- RAG / memory tuning ----
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=4
MEMORY_FACT_LIMIT=15
CHAT_HISTORY_LIMIT=20
EMBEDDING_MODEL=text-embedding-004
CHAT_MODEL=gemini-2.5-flash
